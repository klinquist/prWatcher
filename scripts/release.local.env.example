# Copy this file to scripts/release.local.env. That file is ignored by git.
# Prefer a Keychain profile so no App Store Connect secret is stored in this repo.
#
# Create it once with:
# xcrun notarytool store-credentials prwatcher

export NOTARYTOOL_KEYCHAIN_PROFILE="prwatcher"
export DEVELOPMENT_TEAM="XXXXXXXXXX"

# Alternatively, keep a .p8 key outside this repository and use all three:
# export ASC_KEY_PATH="$HOME/private_keys/AuthKey_XXXXXXXXXX.p8"
# export ASC_KEY_ID="XXXXXXXXXX"
# export ASC_ISSUER_ID="00000000-0000-0000-0000-000000000000"
